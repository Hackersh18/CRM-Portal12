
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me
EMAIL_ADDRESS=you@example.com
EMAIL_PASSWORD=change-me
# Example for cloud Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# DJANGO_DEBUG was set twice; keep it True for local dev
# DJANGO_DEBUG=False
SECRET_KEY=change-me-to-a-strong-secret

# Production over HTTP only (no TLS / no domain yet). Default is true when omitted.
# DJANGO_USE_HTTPS=0

# Database
# Use SQLite when Supabase is unreachable (no internet, DNS error, or "could not translate host name"):
USE_SQLITE_LOCAL=False
# DATABASE_URL=sqlite:///db.sqlite3

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=127.0.0.1,localhost



# Firebase (required for firebase-messaging-sw.js)
FIREBASE_API_KEY=change-me
FIREBASE_AUTH_DOMAIN=change-me.firebaseapp.com
FIREBASE_DATABASE_URL=https://change-me.firebaseio.com
FIREBASE_PROJECT_ID=change-me
FIREBASE_STORAGE_BUCKET=change-me.appspot.com
FIREBASE_MESSAGING_SENDER_ID=change-me
FIREBASE_APP_ID=change-me
FIREBASE_MEASUREMENT_ID=change-me

# Upload limits
MAX_LEAD_IMPORT_MB=10

